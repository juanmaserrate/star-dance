<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Certificado · <%= r.first_name %> <%= r.last_name %></title>
<style>
  body{font-family:Georgia,serif;background:#2a1039;margin:0;padding:24px;color:#2a1039}
  .cert{max-width:820px;margin:0 auto;background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 12px 40px rgba(0,0,0,.4)}
  .top{background:linear-gradient(160deg,#4b2067,#35164a);color:#f0d980;text-align:center;padding:34px 24px;border-bottom:5px solid #d4af37}
  .top img{width:88px;height:88px}
  .top h1{margin:8px 0 0;font-size:2rem;letter-spacing:1px}
  .top .sub{letter-spacing:4px;font-size:.8rem;color:#d4af37;text-transform:uppercase}
  .body{padding:36px 44px;text-align:center}
  .body h2{color:#4b2067;font-size:1.4rem;margin:0 0 18px}
  .name{font-size:2.1rem;color:#35164a;margin:10px 0;border-bottom:2px dashed #d4af37;display:inline-block;padding:0 20px 8px}
  table{width:100%;border-collapse:collapse;margin:24px 0;font-family:'Segoe UI',sans-serif}
  td{padding:10px 12px;border-bottom:1px solid #eee;text-align:left;font-size:.95rem}
  td.k{color:#8a7aa0;width:42%;font-weight:600}
  .foot{display:flex;justify-content:space-between;align-items:center;padding:20px 44px 34px;font-family:'Segoe UI',sans-serif}
  .code{font-family:monospace;background:#f3edfa;color:#4b2067;padding:6px 12px;border-radius:8px;font-size:.9rem}
  .status{font-weight:800;padding:5px 14px;border-radius:20px}
  .pagado{background:#d8f5e3;color:#1c6b41}.pend{background:#ffe1e1;color:#a3283a}
  .print{text-align:center;margin:20px}
  .btn{background:#d4af37;color:#35164a;border:none;padding:12px 26px;border-radius:30px;font-weight:800;cursor:pointer;font-size:1rem}
  @media print{body{background:#fff;padding:0}.print{display:none}.cert{box-shadow:none}}
</style>
</head>
<body>
<div class="print"><button class="btn" onclick="window.print()">🖨 Imprimir / Guardar PDF</button></div>
<div class="cert">
  <div class="top">
    <img src="/img/logo.svg" alt="Star Dance">
    <div class="sub">Liga de Patinaje</div>
    <h1>Star Dance · Patín Artístico</h1>
  </div>
  <div class="body">
    <h2>Certificado de Inscripción</h2>
    <p>La liga certifica la inscripción de</p>
    <div class="name"><%= r.first_name %> <%= r.last_name %></div>
    <table>
      <tr><td class="k">DNI</td><td><%= r.dni || '—' %></td></tr>
      <tr><td class="k">Club</td><td><%= r.club_name || '—' %></td></tr>
      <tr><td class="k">Torneo</td><td><%= r.tname %></td></tr>
      <tr><td class="k">Fecha del torneo</td><td><%= r.tdate ? fmtDate(r.tdate) : 'A confirmar' %></td></tr>
      <tr><td class="k">Sede</td><td><%= r.tloc || 'A confirmar' %></td></tr>
      <tr><td class="k">Categoría</td><td><%= r.cname %><%= r.clevel ? ' · ' + r.clevel : '' %></td></tr>
      <tr><td class="k">Horario</td><td><%= r.cschedule || 'A confirmar' %></td></tr>
      <tr><td class="k">Profesor/a a cargo</td><td><%= r.profe %></td></tr>
    </table>
  </div>
  <div class="foot">
    <span class="code"><%= r.code %></span>
    <span class="status <%= r.paid ? 'pagado' : 'pend' %>"><%= r.paid ? 'PAGO CONFIRMADO' : 'PAGO PENDIENTE' %></span>
  </div>
</div>
</body>
</html>
