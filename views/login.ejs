<div style="max-width:440px;margin:30px auto">
  <div class="center mb">
    <img src="/img/logo.svg" alt="Star Dance" style="width:110px;height:110px">
    <h1 style="color:var(--dorado);margin-top:8px">Star Dance</h1>
    <p class="muted">Ingresá con las credenciales que te dio la liga.</p>
  </div>
  <div class="card">
    <form action="/login" method="POST">
      <label for="username">Nombre de usuario</label>
      <input id="username" name="username" type="text" required autofocus placeholder="ej: profe.ana">
      <label for="password">Contraseña</label>
      <input id="password" name="password" type="password" required placeholder="••••••••">
      <button class="btn btn-gold btn-block mt" type="submit">Iniciar sesión</button>
    </form>
    <p class="hint center mt">¿Sos profe y no tenés usuario? Escribinos por Instagram
      <a href="https://www.instagram.com/stardancesan/" target="_blank">@stardancesan</a>.</p>
  </div>
</div>
