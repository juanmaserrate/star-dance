<div class="section-title"><h1 class="gold">Nuestro jurado</h1></div>
<p class="muted mb">Profesionales que evalúan con mirada técnica y mucho cariño por el deporte. 🌟</p>
<% if (jueces.length === 0) { %>
  <div class="card-dark card">Pronto vamos a presentar al jurado de la temporada.</div>
<% } else { %>
  <div class="grid grid-3">
    <% jueces.forEach(j => { %>
      <div class="judge">
        <% if (j.photo) { %>
          <img src="<%= j.photo %>" class="ava" alt="<%= j.full_name %>">
        <% } else { %>
          <div class="ava"><%= j.full_name.charAt(0) %></div>
        <% } %>
        <h3><%= j.full_name %></h3>
        <% if (j.specialty) { %><span class="badge badge-gold"><%= j.specialty %></span><% } %>
        <% if (j.bio) { %><p class="muted" style="margin-top:10px"><%= j.bio %></p><% } %>
      </div>
    <% }) %>
  </div>
<% } %>
